# Environment Variables — copy to .env and fill in values
# ─────────────────────────────────────────────────────────────────────────────

# Application
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database (PostgreSQL via Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/saas_platform?schema=public"

# JWT Secrets — use long random strings in production (openssl rand -base64 64)
JWT_ACCESS_SECRET=your_super_secret_access_token_key_change_this
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_change_this

# Token Expiry
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Security
BCRYPT_SALT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS (comma-separated origins or * for all)
CORS_ORIGIN=http://localhost:3001
